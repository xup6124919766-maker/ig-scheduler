# ─── 必填 ───
# 登入帳號
ADMIN_USER=admin
# 登入密碼（明碼）— 部署時換用 ADMIN_PASS_HASH（bcrypt hash）更安全
ADMIN_PASS=

# 業主 token 加密金鑰（64 字元 hex；用 `node -e "console.log(crypto.randomBytes(32).toString('hex'))"` 生）
ENCRYPTION_KEY=

# ─── 部署用（Railway 會自動帶入 RAILWAY_PUBLIC_DOMAIN）───
# 自訂網域時填這個（例如 https://ig.example.com）
# PUBLIC_BASE_URL=

# Volume 掛載點（Railway 建議掛 /data，並設這兩項）
# DB_DIR=/data/db
# UPLOAD_DIR=/data/uploads

# ─── 選填 ───
PORT=4567
GRAPH_VERSION=v21.0
NODE_ENV=development
